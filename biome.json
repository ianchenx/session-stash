{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!build/**",
      "!.plasmo/**",
      "!output/**",
      "!assets/screenshots/**",
      "!pnpm-lock.yaml",
      "!components/ui/**"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "css": {
    "linter": {
      "enabled": false
    }
  },
  "javascript": {
    "globals": ["chrome"]
  }
}
