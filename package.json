{
  "name": "session-stash",
  "displayName": "Session Stash",
  "version": "0.1.0",
  "description": "Manage and switch multiple account sessions per site. Encrypted cookie and localStorage sync via Cloudflare KV.",
  "author": "hi@ianx.dev",
  "license": "MIT",
  "homepage": "https://github.com/ianchenx/session-stash#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianchenx/session-stash.git"
  },
  "bugs": {
    "url": "https://github.com/ianchenx/session-stash/issues"
  },
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "plasmo": "0.90.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tldts": "^7.0.28"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.3.3",
    "vitest": "^4.1.4"
  },
  "manifest": {
    "permissions": [
      "cookies",
      "storage",
      "scripting",
      "tabs",
      "activeTab",
      "alarms",
      "sidePanel",
      "favicon"
    ],
    "host_permissions": [
      "https://*/*",
      "https://api.cloudflare.com/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
